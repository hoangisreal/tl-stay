PORT=5000
# Leave MONGO_URI commented for zero-setup demo mode.
# The backend will use in-memory MongoDB and auto-seed demo data.
# Uncomment this line only if you have a local MongoDB server running.
# MONGO_URI=mongodb://localhost:27017/tl-stay
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
NODE_ENV=development
SEED_DEMO_ON_EMPTY=true
